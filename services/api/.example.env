# Local non-Docker workflow only (ports 3000/3001). Root `.example.env` is canonical for Docker (copy to `.env` at repo root).
# Copy to .env before running the API (required)
SECRET_KEY=change-me-before-production
JWT_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
EMAIL_API_KEY=
FRONTEND_URL=http://localhost:3001
# PostgreSQL connection for inventory — copy exact URI from Supabase dashboard (project milestone5_inventory)
# Transaction pooler example (region/host varies — us-west-2 may use aws-1-us-west-2, not aws-0):
# DATABASE_URL=postgresql://postgres.[ref]:[url-encoded-password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres
